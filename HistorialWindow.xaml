<Window x:Class="EventPassMX_programacion.HistorialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historial de Compras"
        Height="520" Width="920"
        Background="#F4F6F9"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 🔷 HEADER -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="🧾"
                       FontSize="28"
                       Margin="0,0,10,0"/>
            <TextBlock Text="Historial de Compras"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#2C3E50"/>
        </StackPanel>

        <!-- 📊 TABLA -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="12">

            <DataGrid x:Name="tablaHistorial"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      RowBackground="White"
                      AlternatingRowBackground="#F8F9FB"
                      SelectionMode="Single">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                    <DataGridTextColumn Header="Evento" Binding="{Binding Evento}" Width="*"/>
                    <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha}" Width="150"/>
                    <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="100"/>
                    <DataGridTextColumn Header="Total ($)" Binding="{Binding Total}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 🔘 BOTONES -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">

            <Button Content="🔄 Actualizar"
                    Width="130"
                    Margin="5"
                    Background="#3498DB"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Padding="10,6"
                    Cursor="Hand"/>

            <Button Content="❌ Cerrar"
                    Width="130"
                    Margin="5"
                    Background="#E74C3C"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Padding="10,6"
                    Cursor="Hand"
                    Click="Cerrar_Click"/>
        </StackPanel>

    </Grid>
</Window>