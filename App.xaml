<Application x:Class="EventPassMX_programacion.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">

    <Application.Resources>

        <!-- 🌌 FONDO GLOBAL -->
        <LinearGradientBrush x:Key="AppBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0A0F1C"/>
            <GradientStop Color="#0D1B2A"/>
        </LinearGradientBrush>

        <!-- 💜 HEADER -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#7F00FF"/>
            <GradientStop Color="#E100FF"/>
        </LinearGradientBrush>

        <!-- 🔥 BOTÓN -->
        <LinearGradientBrush x:Key="NeonButton" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF7A00"/>
            <GradientStop Color="#FF3D00"/>
        </LinearGradientBrush>

        <!-- 🧊 CARD -->
        <SolidColorBrush x:Key="CardBackground" Color="#111827"/>

        <!-- TEXTO -->
        <SolidColorBrush x:Key="PrimaryText" Color="White"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#9CA3AF"/>

        <!-- 🔥 BOTÓN GLOBAL -->
        <Style x:Key="BuyButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btn"
                                CornerRadius="25"
                                Background="{StaticResource NeonButton}">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF3D00"
                                                  BlurRadius="25"
                                                  ShadowDepth="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <!-- ✨ HOVER REAL -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btn" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btn" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 💎 CARD GLOBAL -->
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>